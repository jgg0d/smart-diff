{
  "manifest_version": 3,
  "name": "Smart Diff",
  "version": "1.0.0",
  "description": "Semantic code review assistant — groups and classifies GitHub PR changes using AI.",
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/interface/popup.html",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["src/content/content.js"],
      "css": ["src/styles/injected.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/interface/settings.html",
        "src/styles/settings.css",
        "src/content/pr-parser.js",
        "src/content/dom-injector.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
